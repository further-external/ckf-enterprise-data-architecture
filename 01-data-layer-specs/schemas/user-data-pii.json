{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CKF User Data (PII) Schema",
  "description": "The required RAW user_data object payload for Server-Side SHA256 hashing.",
  "type": "object",
  "properties": {
    "user_data": {
      "type": "object",
      "properties": {
        "email_address": {
          "type": "string",
          "format": "email",
          "description": "Raw, unhashed email address."
        },
        "phone_number": {
          "type": "string",
          "pattern": "^\\+?[1-9]\\d{1,14}$",
          "description": "Raw phone number strictly in E.164 format."
        },
        "address": {
          "type": "object",
          "properties": {
            "first_name": { "type": "string" },
            "last_name": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "region": { "type": "string" },
            "postal_code": { "type": "string" },
            "country": { "type": "string", "maxLength": 2 }
          },
          "required": ["first_name", "last_name"]
        }
      },
      "required": ["email_address"]
    }
  }
}